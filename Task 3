#include <math.h>

#define N 180                     // Number of samples
const int B = 4275;               // B value of the thermistor
const int R0 = 100000;            // R0 = 100kΩ
const int pinTempSensor = A0;     // Grove - Temperature Sensor connected to A0

const int samplingInterval = 1000;  // 1 sample per second
const int collectionTime = 180;     // 3 minutes = 180 seconds
float temperatureData[collectionTime]; // Array to store temperature readings
float magnitude[N];  // Array to store magnitude of frequency components

void collect_temperature_data() {
    for (int i = 0; i < collectionTime; i++) {
        int a = analogRead(pinTempSensor); // Read analog value

        float R = (1023.0 / (float)a) - 1.0;
        R = R0 * R;

        float temperature = 1.0 / (log(R / R0) / B + 1 / 298.15) - 273.15; // Convert to Celsius

        temperatureData[i] = temperature; // Store in array

        Serial.print("Sample ");
        Serial.print(i + 1);
        Serial.print(": Temperature = ");
        Serial.println(temperature);

        delay(samplingInterval); // Maintain 1-second sampling interval
    }
}

float* apply_dft(float* data) {
    static float magnitude[N];  // Static array to persist data after function returns

    for (int k = 0; k < N; k++) {
        float realPart = 0.0;
        float imagPart = 0.0;

        for (int n = 0; n < N; n++) {
            float angle = -2.0 * M_PI * k * n / N;
            realPart += data[n] * cos(angle);
            imagPart += data[n] * sin(angle);
        }

        // Compute magnitude
        magnitude[k] = sqrt(realPart * realPart + imagPart * imagPart);
    }

    return magnitude;  // Return pointer to magnitude array
}

void setup() {
    Serial.begin(9600);
    delay(1000); // Allow serial monitor to initialize
}

void loop() {
    Serial.println("Starting temperature collection cycle...");
    collect_temperature_data(); // Collect data for 3 minutes

    Serial.println("Temperature collection complete. Applying DFT...");
    float* frequency_magnitudes = apply_dft(temperatureData);
    
    Serial.println("DFT Magnitudes:");
    for (int i = 0; i < N; i++) {
        Serial.print("Frequency ");
        Serial.print(i + 1);
        Serial.print(": ");
        Serial.println(frequency_magnitudes[i]);        
    }
    
    Serial.println("Cycle complete. Restarting...");
    delay(1000); // 1-second pause before restarting the next cycle
}
